@prefix : <http://www.semanticweb.org/beyza/ontologies/2026/healthcare#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/beyza/ontologies/2026/healthcare#> .

<http://www.semanticweb.org/beyza/ontologies/2026/healthcare> rdf:type owl:Ontology ;
    rdfs:label "Healthcare Diagnosis Ontology v4" ;
    rdfs:comment "Extended OWL ontology: 50 diseases, 20 patients, SWRL, SHACL, LLM integration." .

############################  Object Properties
:hasSymptom rdf:type owl:ObjectProperty ; rdfs:domain :Disease ; rdfs:range :Symptom ; rdfs:label "has symptom" .
:hasTreatment rdf:type owl:ObjectProperty ; rdfs:domain :Disease ; rdfs:range :Treatment ; rdfs:label "has treatment" .
:reportsSymptom rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :Symptom ; rdfs:label "reports symptom" .
:possibleDiagnosis rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :Disease ; rdfs:label "possible diagnosis" ;
    owl:propertyChainAxiom ( :reportsSymptom [ owl:inverseOf :hasSymptom ] ) .
:requiresTest rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :DiagnosticTest ; rdfs:label "requires test" .
:hasRiskAssessment rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :RiskAssessment ; rdfs:label "has risk assessment" .
:triggersAlert rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :ClinicalAlert ; rdfs:label "triggers alert" .
:basedOnObservation rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :PatientObservation ; rdfs:label "based on observation" .
:hasRecommendation rdf:type owl:ObjectProperty ; rdfs:domain :Patient ; rdfs:range :DiagnosticRecommendation ; rdfs:label "has recommendation" .

############################  Data Properties
:hasSymptomDuration rdf:type owl:DatatypeProperty ; rdfs:domain :Patient ; rdfs:range xsd:integer .
:hasFeverStatus rdf:type owl:DatatypeProperty ; rdfs:domain :Patient ; rdfs:range xsd:string .
:hasRiskLevel rdf:type owl:DatatypeProperty ; rdfs:domain :Patient ; rdfs:range xsd:string .
:hasAge rdf:type owl:DatatypeProperty ; rdfs:domain :Patient ; rdfs:range xsd:integer .
:hasGender rdf:type owl:DatatypeProperty ; rdfs:domain :Patient ; rdfs:range xsd:string .
:hasAlertMessage rdf:type owl:DatatypeProperty ; rdfs:domain :ClinicalAlert ; rdfs:range xsd:string .
:hasDOID rdf:type owl:DatatypeProperty ; rdfs:domain :Disease ; rdfs:range xsd:string .
:hasDescription rdf:type owl:DatatypeProperty ; rdfs:domain :Disease ; rdfs:range xsd:string .
:hasCategory rdf:type owl:DatatypeProperty ; rdfs:domain :Disease ; rdfs:range xsd:string .

############################  Classes
:Patient rdf:type owl:Class ; rdfs:label "Patient" .
:Disease rdf:type owl:Class ; rdfs:label "Disease" .
:Symptom rdf:type owl:Class ; rdfs:label "Symptom" .
:Treatment rdf:type owl:Class ; rdfs:label "Treatment" .
:Diagnosis rdf:type owl:Class ; rdfs:label "Diagnosis" .
:DiagnosticTest rdf:type owl:Class ; rdfs:label "Diagnostic Test" .
:RiskAssessment rdf:type owl:Class ; rdfs:label "Risk Assessment" .
:ClinicalAlert rdf:type owl:Class ; rdfs:label "Clinical Alert" .
:PatientObservation rdf:type owl:Class ; rdfs:label "Patient Observation" .
:DiagnosticRecommendation rdf:type owl:Class ; rdfs:label "Diagnostic Recommendation" .
:ClinicalRule rdf:type owl:Class ; rdfs:label "Clinical Rule" .

