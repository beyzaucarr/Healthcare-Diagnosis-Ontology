############################  Diseases

:Influenza rdf:type owl:NamedIndividual , :Disease ;
    rdfs:label "Influenza" ;
    :hasDOID "DOID:8469" ;
    :hasCategory "Infectious" ;
    :hasDescription "A viral infectious disease located in the respiratory tract" ;
    :hasSymptom :Fever , :Cough , :Headache , :SoreThroat , :Fatigue , :Chills ;
    :hasTreatment :Oseltamivir , :Rest , :Fluids .

:COVID19 rdf:type owl:NamedIndividual , :Disease ;
    rdfs:label "COVID19" ;
    :hasDOID "DOID:0080600" ;
    :hasCategory "Infectious" ;
    :hasDescription "A coronavirus infectious disease characterized by respiratory symptoms" ;
    :hasSymptom :Fever , :Cough , :ShortnessOfBreath , :Fatigue , :LossOfTaste , :Headache ;
    :hasTreatment :SupportiveCare , :Antivirals , :Vaccination .

:Tuberculosis rdf:type owl:NamedIndividual , :Disease ;
    rdfs:label "Tuberculosis" ;
    :hasDOID "DOID:399" ;
    :hasCategory "Infectious" ;
    :hasDescription "A bacterial infectious disease caused by Mycobacterium tuberculosis" ;
    :hasSymptom :Cough , :Fever , :NightSweats , :WeightLoss , :Fatigue , :ChestPain ;
    :hasTreatment :IsoniazidRifampin , :Pyrazinamide , :Ethambutol .

:Pneumonia rdf:type owl:NamedIndividual , :Disease ;
    rdfs:label "Pneumonia" ;
    :hasDOID "DOID:552" ;
    :hasCategory "Infectious" ;
    :hasDescription "Inflammation of the lungs caused by bacterial or viral infection" ;
    :hasSymptom :Fever , :Cough , :ShortnessOfBreath , :ChestPain , :Fatigue , :Chills ;
    :hasTreatment :Antibiotics , :Oxygen , :SupportiveCare .

:Dengue rdf:type owl:NamedIndividual , :Disease ;
    rdfs:label "Dengue" ;
    :hasDOID "DOID:12205" ;
